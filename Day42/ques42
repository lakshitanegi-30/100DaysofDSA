#include <stdio.h>
#include <stdlib.h>

// Node structure for queue
struct Node {
    int data;
    struct Node* next;
};

// Queue structure
struct Queue {
    struct Node* front;
    struct Node* rear;
};

// Initialize queue
void initQueue(struct Queue* q) {
    q->front = q->rear = NULL;
}

// Enqueue operation
void enqueue(struct Queue* q, int val) {
    struct Node* newNode = (struct Node*)malloc(sizeof(struct Node));
    newNode->data = val;
    newNode->next = NULL;

    if (q->rear == NULL) {
        q->front = q->rear = newNode;
        return;
    }
    q->rear->next = newNode;
    q->rear = newNode;
}

// Dequeue operation
int dequeue(struct Queue* q) {
    if (q->front == NULL) {
        return -1; // empty
    }
    struct Node* temp = q->front;
    int val = temp->data;
    q->front = q->front->next;
    if (q->front == NULL) {
        q->rear = NULL;
    }
    free(temp);
    return val;
}

// Display queue
void display(struct Queue* q) {
    struct Node* temp = q->front;
    while (temp != NULL) {
        printf("%d ", temp->data);
        temp = temp->next;
    }
    printf("\n");
}

// Reverse queue using stack
void reverseQueue(struct Queue* q, int n) {
    int stack[n];
    int top = -1;

    // Dequeue all elements into stack
    for (int i = 0; i < n; i++) {
        int val = dequeue(q);
        stack[++top] = val;
    }

    // Enqueue back from stack (reversed order)
    while (top != -1) {
        enqueue(q, stack[top--]);
    }
}

int main() {
    int n;
    scanf("%d", &n);

    struct Queue q;
    initQueue(&q);

    for (int i = 0; i < n; i++) {
        int val;
        scanf("%d", &val);
        enqueue(&q, val);
    }

    reverseQueue(&q, n);
    display(&q);

    return 0;
}
