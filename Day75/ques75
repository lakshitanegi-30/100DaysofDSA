#include <stdio.h>
#include <limits.h>

int main()
{
    int n;
    scanf("%d", &n);

    int arr[n];

    for (int i = 0; i < n; i++)
        scanf("%d", &arr[i]);

    // prefix sum index mapping (using large offset for negatives)
    int offset = 100000;
    int size = 200005;

    int firstIndex[size];

    for (int i = 0; i < size; i++)
        firstIndex[i] = -2;

    int sum = 0;
    int maxLen = 0;

    for (int i = 0; i < n; i++)
    {
        sum += arr[i];

        if (sum == 0)
        {
            maxLen = i + 1;
        }
        else if (firstIndex[sum + offset] != -2)
        {
            int len = i - firstIndex[sum + offset];
            if (len > maxLen)
                maxLen = len;
        }
        else
        {
            firstIndex[sum + offset] = i;
        }
    }

    printf("%d", maxLen);

    return 0;
}
