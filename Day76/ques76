#include <stdio.h>

int adj[1005][1005];
int visited[1005];
int n, m;

void dfs(int u)
{
    visited[u] = 1;

    for (int v = 1; v <= n; v++)
    {
        if (adj[u][v] && !visited[v])
            dfs(v);
    }
}

int main()
{
    scanf("%d %d", &n, &m);

    // initialize
    for (int i = 1; i <= n; i++)
    {
        visited[i] = 0;
        for (int j = 1; j <= n; j++)
            adj[i][j] = 0;
    }

    // build graph (undirected)
    for (int i = 0; i < m; i++)
    {
        int u, v;
        scanf("%d %d", &u, &v);

        adj[u][v] = 1;
        adj[v][u] = 1;
    }

    int components = 0;

    for (int i = 1; i <= n; i++)
    {
        if (!visited[i])
        {
            dfs(i);
            components++;
        }
    }

    printf("%d", components);

    return 0;
}
