# Convert binary tree into mirror image
# Print inorder traversal of mirrored tree

class Node:
    def __init__(self, data):
        self.data = data
        self.left = None
        self.right = None


# Build tree from level order input
def buildTree(arr, n):
    if n == 0 or arr[0] == -1:
        return None

    root = Node(arr[0])
    queue = [root]
    i = 1

    while queue and i < n:
        current = queue.pop(0)

        # Left child
        if i < n and arr[i] != -1:
            current.left = Node(arr[i])
            queue.append(current.left)
        i += 1

        # Right child
        if i < n and arr[i] != -1:
            current.right = Node(arr[i])
            queue.append(current.right)
        i += 1

    return root


# Mirror tree
def mirror(root):
    if root is None:
        return None

    root.left, root.right = root.right, root.left

    mirror(root.left)
    mirror(root.right)


# Inorder traversal
def inorder(root):
    if root:
        inorder(root.left)
        print(root.data, end=" ")
        inorder(root.right)


# Input
n = int(input())
arr = list(map(int, input().split()))

root = buildTree(arr, n)

# Convert to mirror
mirror(root)

# Output inorder traversal
inorder(root)
