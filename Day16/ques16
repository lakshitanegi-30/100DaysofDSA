#include <stdio.h>

int main() {
    int n;
    scanf("%d", &n);

    int arr[n];
    int freq[n]; // to mark visited elements

    // Input array
    for (int i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
        freq[i] = -1; // initialize
    }

    // Count frequencies
    for (int i = 0; i < n; i++) {
        if (freq[i] != -1) continue; // already counted

        int count = 1;
        for (int j = i + 1; j < n; j++) {
            if (arr[i] == arr[j]) {
                count++;
                freq[j] = 0; // mark duplicate
            }
        }
        freq[i] = count;
    }

    // Print results
    for (int i = 0; i < n; i++) {
        if (freq[i] > 0) {
            printf("%d:%d ", arr[i], freq[i]);
        }
    }

    return 0;
}
