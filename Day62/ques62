#include <stdio.h>
#include <stdlib.h>

struct Node
{
    int vertex;
    struct Node* next;
};

// Create new node
struct Node* createNode(int v)
{
    struct Node* temp = (struct Node*)malloc(sizeof(struct Node));
    temp->vertex = v;
    temp->next = NULL;
    return temp;
}

int main()
{
    int n, m;
    scanf("%d", &n);
    scanf("%d", &m);

    struct Node* adj[n];

    // Initialize all heads as NULL
    for (int i = 0; i < n; i++)
        adj[i] = NULL;

    // Input edges
    for (int i = 0; i < m; i++)
    {
        int u, v;
        scanf("%d %d", &u, &v);

        // Add v to u list
        struct Node* newNode1 = createNode(v);
        newNode1->next = adj[u];
        adj[u] = newNode1;

        // Add u to v list (for undirected graph)
        struct Node* newNode2 = createNode(u);
        newNode2->next = adj[v];
        adj[v] = newNode2;
    }

    // Print adjacency list
    for (int i = 0; i < n; i++)
    {
        printf("%d: ", i);

        struct Node* temp = adj[i];
        while (temp != NULL)
        {
            printf("%d ", temp->vertex);
            temp = temp->next;
        }

        printf("\n");
    }

    return 0;
}
